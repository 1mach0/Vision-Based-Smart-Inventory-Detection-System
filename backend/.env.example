# Copy to .env and adjust.

# Database (SQLAlchemy URL).
# PostgreSQL (production):
DATABASE_URL=postgresql+psycopg://vision:vision@localhost:5432/vision
# ...or a zero-setup SQLite demo file (see scripts/seed.py):
# DATABASE_URL=sqlite:///./demo.db

# Vision
YOLO_MODEL_PATH=models/yolo.pt
TESSERACT_CMD=tesseract

# Detections at or below this confidence are routed to human review.
REVIEW_CONFIDENCE_THRESHOLD=0.5
